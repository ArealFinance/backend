# Areal Backend — environment template
# Copy to .env and fill in real values. NEVER commit .env.

# Runtime ----------------------------------------------------------------------
NODE_ENV=development
PORT=3010

# Database ---------------------------------------------------------------------
# Format: postgres://<user>:<pass>@<host>:<port>/<db>
# In production this should be over SSL: append `?sslmode=require`.
DATABASE_URL=postgres://areal:dev-only-change-me@127.0.0.1:5432/areal

# Whether TypeORM should log SQL — keep `false` in production.
TYPEORM_LOGGING=false

# Redis ------------------------------------------------------------------------
# Used by Bull (indexer queue). Format: redis://[:pass@]<host>:<port>/<db>
REDIS_URL=redis://127.0.0.1:6379/0

# JWT --------------------------------------------------------------------------
# Generate with `openssl rand -hex 64`. Rotate on compromise.
JWT_SECRET=change-me-in-production-this-is-an-example
JWT_REFRESH_SECRET=change-me-too-must-differ-from-jwt-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Solana RPC -------------------------------------------------------------------
# Mainnet RPC URL — Helius / QuickNode / private node, NOT public mainnet-beta.
RPC_URL_MAINNET=https://api.mainnet-beta.solana.com
RPC_WS_MAINNET=wss://api.mainnet-beta.solana.com

# Devnet RPC URL.
RPC_URL_DEVNET=https://api.devnet.solana.com
RPC_WS_DEVNET=wss://api.devnet.solana.com

# Which cluster the indexer subscribes to. One of: mainnet | devnet | localnet.
SOLANA_CLUSTER=devnet

# Indexer ----------------------------------------------------------------------
# Backfill window on first deploy (slots; ~216k = 1 day at 400ms slots).
BACKFILL_BLOCKS=216000

# Reconcile cron interval (seconds).
RECONCILE_INTERVAL_SECS=300

# Hard cap on signatures pulled per reconcile sweep — defensive.
MAX_RECONCILE_SIGNATURES=50000

# Metrics ----------------------------------------------------------------------
# /metrics endpoint is served on the same port as the API.
METRICS_ENABLED=true
