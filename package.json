{
  "name": "@areal/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Areal Finance backend — Nest.js indexer + REST API for the 5 on-chain programs",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "migration:generate": "node --loader ts-node/esm ./node_modules/typeorm/cli.js migration:generate -d src/data-source.ts",
    "migration:run": "node --loader ts-node/esm ./node_modules/typeorm/cli.js migration:run -d src/data-source.ts",
    "migration:revert": "node --loader ts-node/esm ./node_modules/typeorm/cli.js migration:revert -d src/data-source.ts",
    "projections:backfill": "node --enable-source-maps dist/cli/projections-backfill.js"
  },
  "dependencies": {
    "@areal/sdk": "file:../sdk",
    "@arlex/client": "file:../vendor/arlex-client-0.3.1.tgz",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.19",
    "@socket.io/redis-adapter": "^8.3.0",
    "@solana/web3.js": "^1.95.4",
    "bs58": "^6.0.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "helmet": "^7.2.0",
    "ioredis": "^5.4.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tweetnacl": "^1.0.3",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
